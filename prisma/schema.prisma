generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum AppRole {
  admin
  gerant
}

enum ChambreStatus {
  disponible
  occupee
  attente_nettoyage
  maintenance
}

enum ChambreCategory {
  standard
  villa_1ch
  villa_2ch
}

enum ReservationSource {
  web
  presence
}

enum WorkflowKind {
  web
  direct
  comptoir
  appel
}

enum ReservationStatus {
  en_attente
  confirmee
  convertie
  refusee
  annulee
  reportee
}

enum ClientGender {
  homme
  femme
  autre
}

enum DocumentType {
  cni
  passport
  titre_sejour
  autre
}

enum StayOffer {
  nuitee
  forfait_semaine
  forfait_weekend
  passage
  villa_1ch
  villa_2ch
  longue_duree
  personnalise
}

enum DiscountType {
  none
  percent
  fixed
}

enum DiscountRequestStatus {
  en_attente
  approuvee
  refusee
  annulee
}

enum StayStatus {
  planifie
  en_cours
  termine
  annule
}

enum PaymentArrangement {
  immediat
  avance_partielle
  fin_sejour
}

enum PaymentStatus {
  solde
  avance_versee
  en_attente_paiement
  solde_en_cours
}

enum PaymentType {
  acompte
  partiel
  solde
}

enum PaymentMethod {
  especes
  mobile_money
  carte
  virement
  autre
}

enum DepositType {
  caution_generale
  caution_villa
}

enum DepositStatus {
  en_attente
  encaissee
  restituee
  conservee
}

enum NoteMoment {
  avant
  apres
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  firstName    String?    @map("first_name")
  lastName     String?    @map("last_name")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  roles              UserRole[]
  auditLogs          AuditLog[]
  requestedDiscounts DiscountRequest[]   @relation("DiscountRequestedBy")
  reviewedDiscounts  DiscountRequest[]   @relation("DiscountReviewedBy")

  @@map("users")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  role      AppRole
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

model Chambre {
  id           String          @id @default(uuid())
  numero       String          @unique
  type         String
  categorie    ChambreCategory @default(standard)
  prix         Decimal         @default(0) @db.Decimal(10, 2)
  capacite     Int             @default(1)
  description  String?         @db.Text
  status       ChambreStatus   @default(disponible)
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  sejours      Sejour[]

  @@map("chambres")
}

model Client {
  id             String        @id @default(uuid())
  firstName      String        @map("first_name")
  lastName       String        @map("last_name")
  email          String?
  phone          String
  nationality    String?
  gender         ClientGender?
  documentNumber String?       @map("document_number")
  documentType   DocumentType? @map("document_type")
  birthDate      DateTime?     @map("birth_date") @db.Date
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  reservations   Reservation[]
  sejours        Sejour[]
  notes          ClientNote[]

  @@index([email])
  @@index([phone])
  @@index([documentNumber])
  @@map("clients")
}

model Reservation {
  id               String            @id @default(uuid())
  reference        String?           @unique @default(cuid())
  clientId         String?           @map("client_id")
  source           ReservationSource @default(web)
  workflowKind     WorkflowKind      @default(web) @map("workflow_kind")
  firstName        String            @map("first_name")
  lastName         String            @map("last_name")
  email            String
  phone            String
  nationality      String?
  gender           ClientGender?
  guestCount       Int?              @map("guest_count")
  dateArrivee      DateTime?         @map("date_arrivee") @db.Date
  dateDepart       DateTime?         @map("date_depart") @db.Date
  offer            StayOffer?        @map("offer")
  customOfferLabel String?           @map("custom_offer_label")
  notes               String?           @db.Text
  requestedAdvanceAmount Decimal?       @map("requested_advance_amount") @db.Decimal(12, 2)
  requestedAdvanceNote   String?        @map("requested_advance_note") @db.Text
  status              ReservationStatus @default(en_attente)
  reportedAt          DateTime?         @map("reported_at")
  dateArriveeOriginal DateTime?         @map("date_arrivee_original") @db.Date
  dateDepartOriginal  DateTime?         @map("date_depart_original") @db.Date
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  client              Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  sejour              Sejour?

  @@index([status, dateArrivee, dateDepart])
  @@map("reservations")
}

model Sejour {
  id                 String             @id @default(uuid())
  code               String             @unique @default(cuid())
  clientId           String             @map("client_id")
  chambreId          String             @map("chambre_id")
  reservationId      String?            @unique @map("reservation_id")
  source             ReservationSource  @default(presence)
  workflowKind       WorkflowKind       @default(direct) @map("workflow_kind")
  status             StayStatus         @default(en_cours)
  offer              StayOffer          @map("offer")
  guestCount         Int?               @map("guest_count")
  customOfferLabel   String?            @map("custom_offer_label")
  plannedStartAt         DateTime?          @map("planned_start_at")
  plannedEndAt           DateTime?          @map("planned_end_at")
  plannedStartAtOriginal DateTime?          @map("planned_start_at_original")
  plannedEndAtOriginal   DateTime?          @map("planned_end_at_original")
  startedAt          DateTime           @map("started_at")
  endedAt            DateTime           @map("ended_at")
  currentEndAt       DateTime           @map("current_end_at")
  baseAmount         Decimal            @default(0) @map("base_amount") @db.Decimal(10, 2)
  discountType       DiscountType       @default(none) @map("discount_type")
  discountValue      Decimal            @default(0) @map("discount_value") @db.Decimal(10, 2)
  discountAmount     Decimal            @default(0) @map("discount_amount") @db.Decimal(10, 2)
  netAmount          Decimal            @default(0) @map("net_amount") @db.Decimal(10, 2)
  amountPaid         Decimal            @default(0) @map("amount_paid") @db.Decimal(10, 2)
  balanceDue         Decimal            @default(0) @map("balance_due") @db.Decimal(10, 2)
  paymentArrangement PaymentArrangement @default(fin_sejour) @map("payment_arrangement")
  paymentStatus      PaymentStatus      @default(en_attente_paiement) @map("payment_status")
  notes              String?            @db.Text
  checkedInAt        DateTime?          @map("checked_in_at")
  checkedOutAt       DateTime?          @map("checked_out_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  client             Client             @relation(fields: [clientId], references: [id], onDelete: Restrict)
  chambre            Chambre            @relation(fields: [chambreId], references: [id], onDelete: Restrict)
  reservation        Reservation?       @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  extensions         StayExtension[]
  payments           Payment[]
  clientNotes        ClientNote[]
  discountRequests   DiscountRequest[]
  deposits           StayDeposit[]

  @@index([chambreId, status, startedAt, currentEndAt])
  @@index([clientId, status])
  @@map("sejours")
}

model StayExtension {
  id               String        @id @default(uuid())
  stayId           String        @map("stay_id")
  startedAt        DateTime      @map("started_at")
  endedAt          DateTime      @map("ended_at")
  offer            StayOffer     @map("offer")
  customOfferLabel String?       @map("custom_offer_label")
  baseAmount       Decimal       @default(0) @map("base_amount") @db.Decimal(10, 2)
  discountType     DiscountType  @default(none) @map("discount_type")
  discountValue    Decimal       @default(0) @map("discount_value") @db.Decimal(10, 2)
  discountAmount   Decimal       @default(0) @map("discount_amount") @db.Decimal(10, 2)
  netAmount        Decimal       @default(0) @map("net_amount") @db.Decimal(10, 2)
  amountPaid       Decimal       @default(0) @map("amount_paid") @db.Decimal(10, 2)
  balanceDue       Decimal       @default(0) @map("balance_due") @db.Decimal(10, 2)
  paymentStatus    PaymentStatus @default(en_attente_paiement) @map("payment_status")
  notes            String?       @db.Text
  createdAt        DateTime      @default(now()) @map("created_at")
  stay             Sejour        @relation(fields: [stayId], references: [id], onDelete: Cascade)
  payments         Payment[]

  @@index([stayId, startedAt, endedAt])
  @@map("sejour_extensions")
}

model Payment {
  id                   String         @id @default(uuid())
  stayId               String         @map("stay_id")
  extensionId          String?        @map("extension_id")
  paidAt               DateTime       @map("paid_at")
  amount               Decimal        @default(0) @db.Decimal(10, 2)
  method               PaymentMethod
  type                 PaymentType
  operator             String?        @db.VarChar(80)
  payerPhone           String?        @map("payer_phone") @db.VarChar(30)
  transactionReference String?        @map("transaction_reference") @db.VarChar(120)
  notes                String?        @db.Text
  createdAt            DateTime       @default(now()) @map("created_at")
  stay                 Sejour         @relation(fields: [stayId], references: [id], onDelete: Cascade)
  extension            StayExtension? @relation(fields: [extensionId], references: [id], onDelete: SetNull)

  @@index([stayId, paidAt])
  @@index([transactionReference])
  @@map("payments")
}

model ClientNote {
  id        String      @id @default(uuid())
  clientId  String      @map("client_id")
  stayId    String?     @map("stay_id")
  moment    NoteMoment
  rating    Int?
  comment   String?     @db.Text
  createdAt DateTime    @default(now()) @map("created_at")
  client    Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  stay      Sejour?     @relation(fields: [stayId], references: [id], onDelete: SetNull)

  @@index([clientId, moment])
  @@map("client_notes")
}

model DiscountRequest {
  id                   String                @id @default(uuid())
  stayId               String                @map("stay_id")
  requestedById        String                @map("requested_by_id")
  reviewedById         String?               @map("reviewed_by_id")
  status               DiscountRequestStatus @default(en_attente)
  discountType         DiscountType          @map("discount_type")
  discountValue        Decimal               @default(0) @map("discount_value") @db.Decimal(10, 2)
  approvedDiscountType DiscountType?         @map("approved_discount_type")
  approvedDiscountValue Decimal?             @map("approved_discount_value") @db.Decimal(10, 2)
  reason               String                @db.Text
  reviewNote           String?               @map("review_note") @db.Text
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  reviewedAt           DateTime?             @map("reviewed_at")
  stay                 Sejour                @relation(fields: [stayId], references: [id], onDelete: Cascade)
  requestedBy          User                  @relation("DiscountRequestedBy", fields: [requestedById], references: [id], onDelete: Restrict)
  reviewedBy           User?                 @relation("DiscountReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([stayId, status])
  @@index([requestedById, status])
  @@map("discount_requests")
}

model StayDeposit {
  id            String        @id @default(uuid())
  stayId         String        @map("stay_id")
  type           DepositType   @default(caution_generale)
  status         DepositStatus @default(en_attente)
  expectedAmount Decimal       @default(0) @map("expected_amount") @db.Decimal(10, 2)
  heldAmount     Decimal       @default(0) @map("held_amount") @db.Decimal(10, 2)
  returnedAmount Decimal       @default(0) @map("returned_amount") @db.Decimal(10, 2)
  method         PaymentMethod?
  notes          String?       @db.Text
  heldAt         DateTime?     @map("held_at")
  returnedAt     DateTime?     @map("returned_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  stay           Sejour        @relation(fields: [stayId], references: [id], onDelete: Cascade)

  @@index([stayId, status])
  @@map("stay_deposits")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  userName   String   @map("user_name")
  action     String
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  details    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([targetType, targetId])
  @@map("audit_logs")
}
